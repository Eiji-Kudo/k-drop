{
	"name": "v2",
	"private": true,
	"version": "0.0.0",
	"packageManager": "pnpm@10.33.0",
	"type": "module",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"dev": "vite",
		"build": "tsc -b && vite build",
		"cf:typegen": "wrangler types worker-configuration.d.ts --env-interface CloudflareEnv --include-runtime false",
		"db:create": "wrangler d1 create k-drop-v2 --binding DB --update-config",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply DB --local",
		"db:execute:local": "wrangler d1 execute DB --local",
		"db:studio": "drizzle-kit studio",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:types": "tsc -b",
		"lint": "eslint .",
		"format": "biome check --write .",
		"format:check": "biome check .",
		"check:all": "pnpm run ci",
		"ci": "pnpm run test && pnpm run test:types && pnpm run lint && pnpm run format:check && pnpm run build",
		"preview": "vite preview",
		"dev:full": "wrangler pages dev --compatibility-date=2026-04-05 -- pnpm run dev"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"@tanstack/react-query": "5.96.2",
		"@tanstack/react-router": "1.168.10",
		"drizzle-orm": "^0.45.2",
		"hono": "4.12.10",
		"lucide-react": "^1.7.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.72.1",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@cloudflare/workers-types": "4.20260405.1",
		"@eslint/js": "^9.39.4",
		"@tailwindcss/vite": "4.2.2",
		"@tanstack/router-plugin": "1.167.12",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.15.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"better-sqlite3": "^12.8.0",
		"daisyui": "5.5.19",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.4.0",
		"happy-dom": "^20.8.9",
		"jsdom": "^29.0.1",
		"tailwindcss": "4.2.2",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^8.0.1",
		"vitest": "^4.1.2",
		"wrangler": "4.80.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["better-sqlite3"]
	}
}
